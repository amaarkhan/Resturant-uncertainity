generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String      @id @default(cuid())
  fullName     String
  email        String      @unique
  passwordHash String
  role         String
  restaurantId String?
  restaurant   Restaurant? @relation(fields: [restaurantId], references: [id])
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model Restaurant {
  id                 String              @id @default(cuid())
  name               String
  city               String
  timezone           String
  active             Boolean             @default(true)
  operatingDays      String              @default("Mon,Tue,Wed,Thu,Fri,Sat,Sun")
  weatherEnabled     Boolean             @default(true)
  eventsEnabled      Boolean             @default(true)
  weatherWeight      Float               @default(1.0)
  eventWeight        Float               @default(1.0)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  users              User[]
  menuItems          MenuItem[]
  recommendationRuns RecommendationRun[]
  outcomes           DailyOutcome[]
  feedback           QuickFeedback[]
}

model MenuItem {
  id              String   @id @default(cuid())
  restaurantId    String
  restaurant      Restaurant @relation(fields: [restaurantId], references: [id])
  name            String
  unit            String
  baselinePrepQty Int
  cost            Float    @default(0.0)
  price           Float    @default(0.0)
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([restaurantId])
}

model RecommendationRun {
  id              String   @id @default(cuid())
  restaurantId    String
  restaurant      Restaurant @relation(fields: [restaurantId], references: [id])
  date            String
  confidenceLevel String
  reasonSummary   String
  usedFallback    Boolean
  signalsUsed     String
  createdAt       DateTime @default(now())
  items           RecommendationItem[]

  @@index([restaurantId, date])
}

model RecommendationItem {
  id                  String   @id @default(cuid())
  recommendationRunId String
  recommendationRun   RecommendationRun @relation(fields: [recommendationRunId], references: [id])
  menuItemId          String
  itemName            String
  baselineQty         Int
  recommendedQty      Int
  adjustmentFactor    Float
  reason              String
}

model DailyOutcome {
  id                    String   @id @default(cuid())
  restaurantId          String
  restaurant            Restaurant @relation(fields: [restaurantId], references: [id])
  date                  String
  menuItemId            String
  preparedQty           Int
  soldQty               Int
  leftoverQty           Int
  stockout              Boolean
  recommendationFollowed Boolean
  createdAt             DateTime @default(now())

  @@unique([restaurantId, date, menuItemId])
  @@index([restaurantId, date])
}

model QuickFeedback {
  id               String   @id @default(cuid())
  restaurantId     String
  restaurant       Restaurant @relation(fields: [restaurantId], references: [id])
  date             String
  feedbackType     String
  confidenceRating Int
  note             String   @default("")
  createdAt        DateTime @default(now())

  @@index([restaurantId, date])
}

model ApiMetric {
  id         String   @id @default(cuid())
  method     String
  path       String
  statusCode Int
  latencyMs  Float
  createdAt  DateTime @default(now())
}
