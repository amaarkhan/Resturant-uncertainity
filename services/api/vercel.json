{
  "functions": {
    "api/[...route].js": {
      "maxDuration": 30
    },
    "api/health.js": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/health",
      "destination": "/api/health.js"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/[...route].js"
    }
  ]
}
