{
  "version": 2,
  "functions": {
    "api/index.js": {
      "maxDuration": 30
    },
    "api/health.js": {
      "maxDuration": 10
    }
  },
  "routes": [
    {
      "src": "/health",
      "dest": "api/health.js"
    },
    {
      "src": "/api/(.*)",
      "dest": "api/index.js"
    }
  ]
}
